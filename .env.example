# --- Database ---
# Owner/superuser role: DDL, migrations, bootstrap only.
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis_dev_password
POSTGRES_DB=aegis
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Least-privilege runtime role that all request traffic uses (RLS applies to it).
APP_DB_USER=aegis_app
APP_DB_PASSWORD=aegis_app_password

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Application ---
# Generate a real secret for production: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-only-insecure-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000

# --- Seed (first-run bootstrap org + admin) ---
SEED_DATA=true
SEED_ORG_NAME=Acme Corp
SEED_ORG_SLUG=acme
SEED_ADMIN_EMAIL=admin@acme.com
SEED_ADMIN_PASSWORD=ChangeMe123!

# --- Frontend ---
# Browser-facing origin of THIS deployment, incl. scheme + port. nginx serves the
# app and proxies /api on the same origin, so this is just the external URL users
# hit. Baked into the web bundle at BUILD time — rebuild `web` after changing it
# (docker compose -f docker-compose.prod.yml up -d --build web).
# Prod example on a shared host using a custom port: https://18.142.228.92:8443
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# --- Reverse-proxy host ports (prod compose) ---
# nginx publishes these on the host. Leave at 80/443 for a dedicated host; change
# them when those ports are already in use (e.g. another app on the same box).
# Only open the port you actually use in the cloud firewall / AWS Security Group.
HTTP_PORT=80
HTTPS_PORT=443

# --- Authentication hardening (banking baseline) ---
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_COMPLEXITY=true
PASSWORD_EXPIRY_DAYS=0
MAX_FAILED_LOGINS=5
LOCKOUT_MINUTES=15
MFA_REQUIRED=false
MFA_ISSUER=NexusLine GRC
LDAP_ENABLED=false
ENFORCE_SEGREGATION_OF_DUTIES=true

# --- Outbound email (SMTP). Leave SMTP_HOST empty to log instead of send. ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=NexusLine GRC <no-reply@nexusline.local>
SMTP_USE_TLS=true
APP_BASE_URL=http://localhost:3000

# --- Background scheduler (reminders / chasing / digests) ---
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=15

# --- File storage (binary uploads) ---
FILE_STORAGE_DIR=/data/uploads
MAX_UPLOAD_MB=25

# --- On-prem productionization ---
APP_VERSION=1.0.0
DEPLOYMENT_MODE=on-prem
BACKUP_DIR=/data/backups
# Offline licensing (Ed25519, no phone-home). Vendor: `python -m app.tools.license keygen`.
ENFORCE_LICENSE=false
LICENSE_FILE=./deploy/license.key
LICENSE_PUBLIC_KEY_PATH=./deploy/license_pubkey.pem
